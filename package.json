{
  "name": "fmkorea-preview",
  "displayName": "Fmkorea preview - 에펨코리아 게시글 미리보기",
  "version": "3.0.4",
  "description": "창을 이동하지 않고 게시글을 미리 봅니다.",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.325",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "plasmo": "latest",
    "postcss": "^8.5.4",
    "tailwindcss": "^3",
    "typescript": "~6.0.2"
  },
  "manifest": {
    "host_permissions": [
      "https://www.fmkorea.com/*"
    ],
    "permissions": [
      "storage"
    ]
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@swc/core"
  ],
  "postcss": {
    "plugins": {
      "tailwindcss": {},
      "autoprefixer": {}
    }
  }
}